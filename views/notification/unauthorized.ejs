<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>401 - Unauthorized</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: #f4f6f8;
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100vh;
    }
    .card {
      background: #fff;
      padding: 40px;
      border-radius: 8px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
      text-align: center;
      max-width: 420px;
      width: 100%;
    }
    h1 {
      margin: 0;
      font-size: 72px;
      color: #e74c3c;
    }
    h2 {
      margin: 10px 0 20px;
      font-weight: normal;
      color: #333;
    }
    p {
      color: #666;
      font-size: 14px;
      margin-bottom: 25px;
    }
    .btn {
      text-decoration: none;
      padding: 10px 18px;
      border-radius: 4px;
      background: #3498db;
      color: #fff;
      font-size: 14px;
    }
    .btn:hover {
      background: #2980b9;
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>401</h1>
    <h2>Anda tidak memiliki akses</h2>
    <p>
      You do not have permission to access this page.<br/>
      Please login with the correct account.
    </p>

    <a href="/go_to_the_dashboard" class="btn">Go to Login</a>
  </div>
</body>
</html>