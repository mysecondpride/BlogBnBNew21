<button class="searchBtn">🔍 Search</button>

<!-- Search bar (included via partial) -->
<div class="searchBar">
  <div class="container">
    <form action="/search" method="POST">
      <input
        type="search"
        id="searchInput"
        name="searchTerm"
        placeholder="Search here..."
        class="searchBarInput"
        required
      />
      <button type="submit">Search</button>
    </form>
    <div id="searchClose" style="cursor: pointer;">✖ Close</div>
  </div>
</div>
