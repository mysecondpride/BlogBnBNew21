<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Summernote Image Upload</title>

    <link
      href="https://cdn.jsdelivr.net/npm/summernote/dist/summernote-lite.min.css"
      rel="stylesheet"
    />

    <style>
      body {
        font-family: sans-serif;
        padding: 20px;
      }

      input[type="text"],
      button {
        display: block;
        width: 100%;
        padding: 8px;
        margin-bottom: 10px;
        font-size: 1rem;
      }

      #summernote {
        margin-bottom: 10px;
      }
    </style>
  </head>
  <body>
    <h2>Post Blog</h2>

    <form action="/postblog" method="POST">
      <input type="text" name="title" required />
      <textarea id="summernote" name="content" required></textarea>
      <button type="submit">Submit</button>
    </form>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/summernote/dist/summernote-lite.min.js"></script>

    <script>
      $(document).ready(function () {
        $("#summernote").summernote({
          // popover: {
          //   image: [
          //     ["resize", ["resizeFull", "resizeHalf", "resizeQuarter"]],
          //     ["float", ["floatLeft", "floatRight", "floatNone"]],
          //     ["remove", ["removeMedia"]],
          //   ],
          // },
          height: 250,
          callbacks: {
            onImageUpload: function (files) {
              const formData = new FormData();
              formData.append("images", files[0]);
              // for (let i = 0; i < files.length; i++) {
              //   formData.append("images", files[i]);
              // }

              //disinilah kontrak client post gambar dimulai dg postBlog
              fetch("/upload-image", {
                method: "POST",
                body: formData,
              })
                .then((res) => res.json())
                .then((data) => {
                  $("#summernote").summernote("insertImage", data.url);
                  console.log(data);
                })

                .catch((err) => {
                  console.error("Upload failed:", err);
                  alert("Image upload failed!");
                });

              // $("#summernote").summernote({
              //   height: 300,
              //   callbacks: {
              //     onMediaDelete: function ($target) {
              //       // const imageSrc = target[0].src;
              //       const fileId = $target.data("file-id");
              //       // const src = $target.attr("src")
              //       //dimana letak kirim file_id nya
              //       fetch("/delete-image", {
              //         method: "POST",
              //         headers: {
              //           "Content-Type": "application/json",
              //         },
              //         body: JSON.stringify({ fileId }),
              //       })
              //         .then((res) => res.json())
              //         .then((data) => {
              //           console.log("image deleted from server", data);
              //         });
              //     },
              //   },
              // });
            },
          },
        });
      });
    </script>
  </body>
</html>
