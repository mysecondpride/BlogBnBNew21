      <input type="submit" value="delete" />
    </form>

    <form action="/edit-item-input/<%= item._id %>/<%= element2._id %>" method="get">
      <input type="submit" value="edit" />
    </form>



  <% }) %>

<% }) %>
</div>


<!-- ================= PRODUK 3 ================= -->
<div>
<% data.forEach(item => { 
     const produk3 = item.Produk3 || [];
%>

  <% if (produk3.length > 0) { %>
    <p>produk: <%= produk3[0].NamaProduk3 %></p>
    <p>harga: <%= produk3[0].Harga3 %></p>
    <p>stok: <%= produk3[0].Stok3 %></p>
    <p>Keterangan: <%= produk3[0].Keterangan3 %></p>
  <% } %>

  <% produk3.forEach(element3 => { 
       const images = element3.fileImages || [];
  %>

    <% images.forEach(img => { %>
      <img src="/imagesofproducts/<%=item._id %>/<%= img.fileId %>" height="200" width="150">
     <form action="/delete-item-image/Produk3/<%= item._id %>/<%= img.fileId %>?_method=DELETE" method="POST">
  <input type="submit" value="delete-gambar" />
</form>
    </form>
    <% }) %>

    <form action="/delete-item3/<%= item._id %>/<%= element3._id %>?_method=DELETE" method="POST">
      <input type="submit" value="delete" />
    </form>

    <form action="/edit-item-input/<%= item._id %>/<%= element3._id %><%= element3._id %>" method="get">
      <input type="submit" value="edit" />
    </form>

  

  <% }) %>

<% }) %>
</div>

</body>
</html>