<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard</title>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

  <!-- Font klasik -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=IBM+Plex+Sans&display=swap" rel="stylesheet" />

  <style>
    body {
      margin: 0;
      background: #f5f1e6;
      font-family: 'IBM Plex Sans', sans-serif;
      color: #2b2b2b;
    }

    /* HEADER */
    .header {
      padding: 25px 60px;
      background: #fff;
      border-bottom: 4px solid #b89b5e;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .logo {
      font-family: 'Playfair Display', serif;
      font-size: 28px;
      color: #6b4f3b;
    }

    .menuToggle {
      background: #6b4f3b;
      color: white;
      border: none;
      padding: 10px 18px;
      cursor: pointer;
    }

    /* SLIDE MENU */
    .mainMenu {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      background: #fff;
      border-bottom: 4px solid #b89b5e;
      display: flex;
      justify-content: center;
      gap: 60px;
      padding: 30px 0;
      transform: translateY(-100%);
      transition: transform 0.4s ease;
      z-index: 999;
    }

    .mainMenu.open {
      transform: translateY(0);
    }

    .mainMenu a {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      text-decoration: none;
      color: #6b4f3b;
      position: relative;
    }

    .mainMenu a::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: -4px;
      width: 0%;
      height: 2px;
      background: #b89b5e;
      transition: width 0.3s;
    }

    .mainMenu a:hover::after {
      width: 100%;
    }

    /* CONTENT */
    .container {
      padding: 40px 80px;
    }

    .admin-title {
      list-style: none;
      margin-bottom: 40px;
      color: darkorange;
    }

    .button {
      display: inline-block;
      background: magenta;
      color: black;
      padding: 8px 14px;
      text-decoration: none;
      margin-right: 10px;
    }

    .article-item {
      margin-bottom: 30px;
      padding-bottom: 15px;
      border-bottom: 1px solid #ddd2c3;
    }

    .article-item a {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      color: #2b2b2b;
      text-decoration: none;
    }

    .pagination {
      display: inline-block;
      margin-top: 40px;
      font-size: 18px;
      text-decoration: none;
      color: #6b4f3b;
    }
  </style>
</head>

<body>
  <!-- CONTENT -->
  <div class="container">

    <li class="admin-title">
      <h2>Your Dashboard</h2>

      <a href="/getsummernote" class="button">Post Blog</a>
      <a href="/getPostProfile" class="button">Post Profile</a>
       <a href="/display-products" class="button">Tom's Store</a>
    </li>

    <% if (data && data.length > 0) { %>
      <% data.forEach(item => { %>
        <% if (item && item._id) { %>
          <% const element1 = item.element1 %>
          <% if (element1 && element1.length > 0) { %>
            <% const first = element1[0] %>

            <div class="article-item">
              <a href="/eachArticle/<%= item._id %>"><%= first.title %></a>

           <form action="/edit-postBlog/<%= item._id %>" method="GET">
  <button type="submit" class="btn">Edit</button>
</form>
              <button class="delete-btn" data-id="<%= item._id %>">
                delete-blog
              </button>
            </div>

          <% } %>
        <% } %>
      <% }) %>
    <% } else { %>
      <p>Tidak ditemukan data</p>
    <% } %>

    <% if (nextPage !== null) { %>
      <a href="/dashboard?page=<%= nextPage %>" class="pagination">
        &lt; view older post
      </a>
    <% } %>

  </div>

  <!-- SCRIPT -->
  <script>
    // Toggle menu
    $("#menuToggle").on("click", function () {
      $("#mainMenu").toggleClass("open");
    });

    // Delete blog (tetap sama)
    document.querySelectorAll(".delete-btn").forEach(btn => {
      btn.addEventListener("click", async (e) => {
        e.preventDefault();
        const id = btn.dataset.id;
        const ok = confirm("Pastikan GAMBAR sudah dihapus!\nYakin mau hapus blog ini?");
        if (!ok) return;

        const res = await fetch(`/delete-blog/${id}`, { method: "DELETE" });
        const data = await res.json();
        alert(data.message);
        location.reload();
      });
    });
  </script>

</body>
</html>