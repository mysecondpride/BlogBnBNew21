<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tom's Coding and Software Store</title>
</head>
<body>

<!-- ================= PRODUK 1 ================= -->
<div>
<% data.forEach(item => { 
     const produk1 = item.Produk1 || [];
%>

  <% if (produk1.length > 0) { 
       const first = produk1[0]; %>

    <p>produk: <%= first.NamaProduk1 %></p>
    <p>harga: <%= first.Harga1 %></p>
    <p>stok: <%= first.Stok1 %></p>
    <p>keterangan: <%= first.Keterangan1 %></p>

  <% } %>

  <% produk1.forEach(element1 => { 
       const images = element1.fileImages || [];
  %>

    <% images.forEach(img => { %>
      <img src="/files/<%= img.fileId %>" height="200" width="150">
    <% }) %>

  <% }) %>

<% }) %>
</div>


